PORT=3001
# If you change PORT, open the site at http://localhost:YOUR_PORT/ (same port serves HTML + /api).
# No frontend change needed. If EADDRINUSE: netstat -ano | findstr :YOUR_PORT then taskkill /PID ... /F

MONGO_URI=mongodb://localhost:27017/bookstore
# You can use MONGODB_URI instead (same value) — both names work in server/db.js and on Vercel.
# MongoDB must be running locally, or set Atlas URI. If Mongo fails, check server console.

# Razorpay — Key ID and Key Secret from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret

# Optional: allow test orders without Razorpay (no real charge). Do not enable in production.
# ENABLE_DEMO_PAYMENT=true

# Auth (set a long random string in production / on Vercel)
# JWT_SECRET=your-secret-here

# Split deploy (static frontend on another host): browser origin(s), comma-separated, no trailing slash
# Example: FRONTEND_ORIGIN=https://my-store.vercel.app
# FRONTEND_ORIGIN=

# Vercel / serverless: skip bulk book seed on cold start (seed Atlas once via local npm start or Compass)
# SKIP_BOOK_SEED=true
